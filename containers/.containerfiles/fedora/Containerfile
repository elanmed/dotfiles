FROM fedora:43

RUN dnf install -y git zsh which hostname libatomic nc openssl && \
    dnf clean all

ENV SHELL=/usr/bin/zsh

RUN git clone https://github.com/elanmed/dotfiles ~/.dotfiles && \
    cd ~/.dotfiles && \
    sed -i 's|git@github.com:|https://github.com/|g' .gitmodules

RUN cd ~/.dotfiles && bash bootstrap.sh -p dnf -d headless
