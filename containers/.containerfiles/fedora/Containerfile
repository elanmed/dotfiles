FROM fedora:43

RUN dnf install -y git zsh which hostname libatomic nc && \
    dnf clean all

ENV SHELL=/usr/bin/zsh

RUN git clone https://github.com/elanmed/dotfiles "$HOME/.dotfiles" && \
    cd "$HOME/.dotfiles" && \
    sed -i 's|git@github.com:|https://github.com/|g' .gitmodules

RUN cd "$HOME/.dotfiles" && bash bootstrap.sh -p dnf -d headless
