#!/bin/bash
source "$HOME/.dotfiles/_helpers.sh"
usage="usage: nvvm update"

if [[ $1 != "update" ]]; then
  h_echo error "$usage"
  exit 1
fi

mkdir -p "$HOME/.local/share/nvvm/"
tar_path="$HOME/.local/share/nvvm/neovim.tar.gz"

if [[ "$(uname -s)" == "Linux" ]]; then
  asset_name="nvim-linux-x86_64.tar.gz"
  download_url="https://github.com/neovim/neovim/releases/download/nightly/nvim-linux-x86_64.tar.gz"
elif [[ "$(uname -m)" == "arm64" ]]; then
  asset_name="nvim-macos-arm64.tar.gz"
  download_url="https://github.com/neovim/neovim/releases/download/nightly/nvim-macos-arm64.tar.gz"
else
  asset_name="nvim-macos-x86_64.tar.gz"
  download_url="https://github.com/neovim/neovim/releases/download/nightly/nvim-macos-x86_64.tar.gz"
fi

curl --silent --location --output "$tar_path" "$download_url"

latest_release=$(curl --silent "https://api.github.com/repos/neovim/neovim/releases/tags/nightly")
expected_hash=$(
  echo "$latest_release" | jq --raw-output ".assets[] | select(.name == \"$asset_name\") | .digest | split(\":\") | .[1]"
)
actual_hash=$(sha256sum "$tar_path" | cut -d ' ' -f 1)

if [[ $expected_hash != "$actual_hash" ]]; then
  echo "SHA256 mismatch!" >&2
  exit 1
fi

if h_is_macos; then
  macos_arch_dir="nvim-macos-$(uname -m)"
  xattr -c "$tar_path"
  tar --extract --gzip --file="$tar_path" --directory "$HOME/.local/share/nvvm/"
  ln -sf "$HOME/.local/share/nvvm/$macos_arch_dir/bin/nvim" "$HOME/.local/bin/nvim"
else
  tar --extract --gzip --file="$tar_path" --directory="$HOME/.local/share/nvvm/"
  ln -sf "$HOME/.local/share/nvvm/nvim-linux-x86_64/bin/nvim" "$HOME/.local/bin/nvim"
fi
